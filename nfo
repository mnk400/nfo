#!/bin/bash
#
# nfo: a minimal, pretty fetch program written in bash
# Created by Manik

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly OS="$(uname)"
readonly VERSION="0.dev"

readonly LEFT_MARGIN=2
readonly GAP=4

ACCENT=""
DIM=""
RESET=""

# Config-loaded vars, declared with defaults so set -u stays happy
ART="nfo"
TINT="Cyan"
DOTS="small"
SHOW_HOST="True"
INFO_ROWS=()

CONFIG_FILE=""
ART_DIR=""
DEV_MODE=0

set -euo pipefail

show_usage() {
    cat <<EOF
nfo $VERSION

Usage:
  nfo [--help] [--version]

Options:
  -h, --help                  Show this help message
  -v, --version               Show version information
EOF
}

show_version() {
    echo "nfo $VERSION"
}

init_config() {
    local base_dir

    if [[ "${1:-}" == "--super-secret-dev-mode" ]]; then
        DEV_MODE=1
        base_dir="$SCRIPT_DIR"
    else
        base_dir="$HOME/.config/nfo"
    fi

    CONFIG_FILE="$base_dir/nfo.conf"
    ART_DIR="$base_dir/art"

    if [[ ! -f "$CONFIG_FILE" ]]; then
        echo "Error: Config file not found at $CONFIG_FILE" >&2
        if [[ -f "$base_dir/config.conf" ]]; then
            echo "Found a legacy config.conf — nfo's config format changed; copy the new nfo.conf default into $base_dir/" >&2
        fi
        exit 1
    fi
    [[ -d "$ART_DIR" ]] || { echo "Error: Art directory not found at $ART_DIR" >&2; exit 1; }

    set +euo pipefail
    source "$CONFIG_FILE"
    set -euo pipefail
}

setup_styling() {
    RESET=$'\033[0m'
    DIM=$'\033[2m'
    case "${TINT:-Cyan}" in
        Red)     ACCENT=$'\033[31m' ;;
        Green)   ACCENT=$'\033[32m' ;;
        Yellow)  ACCENT=$'\033[33m' ;;
        Blue)    ACCENT=$'\033[34m' ;;
        Magenta) ACCENT=$'\033[35m' ;;
        Cyan)    ACCENT=$'\033[36m' ;;
        *)       ACCENT=$'\033[36m' ;;
    esac
}

# ----- data sources: each returns a value string, no label, no styling -----

get_os() {
    local result
    case "$OS" in
        Linux)
            if [[ -f /etc/os-release ]]; then
                set +u
                source /etc/os-release
                result="$NAME ${VERSION_ID:-}"
                set -u
            else
                result="Linux"
            fi
            ;;
        Darwin)
            local v
            v="$(sw_vers -productVersion 2>/dev/null || echo unknown)"
            result="macOS $v"
            ;;
        *) result="$OS" ;;
    esac
    if [[ "$OS" == "Linux" ]] && grep -q microsoft /proc/version 2>/dev/null; then
        result="$result (WSL)"
    fi
    printf '%s' "$result"
}

get_krn() {
    local v
    v="$(uname -r)"
    case "$OS" in
        Darwin) printf 'Darwin %s' "$v" ;;
        Linux)  printf 'Linux %s'  "$v" ;;
        *)      printf '%s' "$v" ;;
    esac
}

get_mem() {
    local used_mb=0 total_mb=0
    case "$OS" in
        Linux)
            if [[ -f /proc/meminfo ]]; then
                total_mb="$(awk '/^MemTotal:/ {print int($2/1024)}' /proc/meminfo)"
                local avail_mb
                avail_mb="$(awk '/^MemAvailable:/ {print int($2/1024)}' /proc/meminfo)"
                used_mb="$((total_mb - avail_mb))"
            else printf 'unknown'; return; fi
            ;;
        Darwin)
            local page_size total_bytes free_pages free_mb
            page_size="$(sysctl -n hw.pagesize 2>/dev/null)" || page_size=4096
            total_bytes="$(sysctl -n hw.memsize 2>/dev/null)" || total_bytes=0
            total_mb="$((total_bytes / 1024 / 1024))"
            free_pages="$(vm_stat 2>/dev/null | awk '
                /Pages free:/        {gsub(/\./,"",$3); f=$3}
                /Pages inactive:/    {gsub(/\./,"",$3); i=$3}
                /Pages speculative:/ {gsub(/\./,"",$3); s=$3}
                END {print f + i + s}')" || free_pages=0
            free_mb="$(( free_pages * page_size / 1024 / 1024 ))"
            used_mb="$((total_mb - free_mb))"
            ;;
        *) printf 'unknown'; return ;;
    esac
    if (( total_mb <= 0 )); then printf 'unknown'; return; fi
    awk "BEGIN {printf \"%.1f / %.1f GiB\", $used_mb/1024, $total_mb/1024}"
}

get_cpu() {
    local v=""
    case "$OS" in
        Linux)
            v="$(lscpu 2>/dev/null | awk -F': ' '/Model name/ {print $2; exit}' | sed 's/^[[:space:]]*//')" || true
            if [[ -z "$v" ]]; then
                v="$(awk -F': ' '/model name/ {print $2; exit}' /proc/cpuinfo 2>/dev/null | sed 's/^[[:space:]]*//')" || true
            fi
            ;;
        Darwin)
            v="$(sysctl -n machdep.cpu.brand_string 2>/dev/null || echo unknown)"
            ;;
    esac
    printf '%s' "${v:-unknown}"
}

get_up() {
    local secs=0
    case "$OS" in
        Linux)
            [[ -f /proc/uptime ]] && secs="$(awk '{print int($1)}' /proc/uptime)"
            ;;
        Darwin)
            local bt
            bt="$(sysctl -n kern.boottime 2>/dev/null | awk '{gsub(/,/,"",$4); print $4}')" || bt=""
            [[ -n "$bt" ]] && secs="$(( $(date +%s) - bt ))"
            ;;
    esac
    if (( secs <= 0 )); then printf 'unknown'; return; fi
    local d h m
    d=$((secs / 86400))
    h=$(( (secs % 86400) / 3600 ))
    m=$(( (secs % 3600) / 60 ))
    if   (( d > 0 )); then printf '%dd %dh' "$d" "$h"
    elif (( h > 0 )); then printf '%dh %dm' "$h" "$m"
    else                   printf '%dm' "$m"
    fi
}

get_sh() {
    local v=""
    v="$("$SHELL" --version 2>/dev/null | head -1 | cut -d',' -f1 | awk '{print $1, $2}')" || true
    printf '%s' "${v:-$(basename "$SHELL")}"
}

get_pkg() {
    local count=""
    case "$OS" in
        Linux)
            if command -v dpkg-query >/dev/null 2>&1; then
                count="$(dpkg-query -f '${binary:Package}\n' -W 2>/dev/null | wc -l | tr -d ' ') (dpkg)"
            elif command -v rpm >/dev/null 2>&1; then
                count="$(rpm -qa 2>/dev/null | wc -l | tr -d ' ') (rpm)"
            elif command -v pacman >/dev/null 2>&1; then
                count="$(pacman -Q 2>/dev/null | wc -l | tr -d ' ') (pacman)"
            fi
            ;;
        Darwin)
            if command -v brew >/dev/null 2>&1; then
                count="$(brew list --formula 2>/dev/null | wc -l | tr -d ' ') (brew)"
            fi
            ;;
    esac
    printf '%s' "${count:-unknown}"
}

get_dsk() {
    local v
    v="$(df -k / 2>/dev/null | awk 'NR==2 {
        total=$2; avail=$4; used=total-avail;
        printf "%.0f / %.0f GiB", used/1024/1024, total/1024/1024
    }')" || v=""
    printf '%s' "${v:-unknown}"
}

get_res() {
    local v=""
    case "$OS" in
        Linux)
            if command -v xdpyinfo >/dev/null 2>&1; then
                v="$(timeout 2s xdpyinfo 2>/dev/null | awk '/dimensions:/ {printf sep $2; sep=", "}')" || true
            fi
            ;;
        Darwin)
            v="$(system_profiler SPDisplaysDataType 2>/dev/null | awk '/Resolution:/ {printf sep $2 " x " $4; sep=", "}')" || true
            ;;
    esac
    printf '%s' "${v:-unknown}"
}

get_term() {
    printf '%s' "${TERM_PROGRAM:-unknown}"
}

get_ip() {
    local ip=""
    case "$OS" in
        Linux)  ip="$(hostname -I 2>/dev/null | awk '{print $1}')" || true ;;
        Darwin) ip="$(ipconfig getifaddr en0 2>/dev/null || ipconfig getifaddr en1 2>/dev/null || true)" ;;
    esac
    printf '%s' "${ip:-unknown}"
}

get_bat() {
    case "$OS" in
        Darwin)
            local out percent=""
            out="$(pmset -g batt 2>/dev/null)" || out=""
            if [[ "$out" == *InternalBattery* ]]; then
                percent="$(grep -o -m 1 '[0-9]\+%' <<< "$out")" || percent=""
                [[ -n "$percent" ]] && printf '%s' "$percent"
            fi
            ;;
        Linux)
            local bat_path="" candidate percent=""
            for candidate in /sys/class/power_supply/BAT0 /sys/class/power_supply/BAT1; do
                if [[ -d "$candidate" ]]; then bat_path="$candidate"; break; fi
            done
            if [[ -n "$bat_path" && -r "$bat_path/capacity" ]]; then
                read -r percent < "$bat_path/capacity" || true
                [[ -n "$percent" ]] && printf '%s%%' "$percent"
            fi
            ;;
    esac
}

get_host_line() {
    local h
    h="$(hostname -s 2>/dev/null || echo host)"
    printf '%s@%s' "${USER:-user}" "$h"
}

# ----- composition -----

build_row() {
    local key="$1" value
    case "$key" in
        os)   value="$(get_os)"   ;;
        krn)  value="$(get_krn)"  ;;
        up)   value="$(get_up)"   ;;
        sh)   value="$(get_sh)"   ;;
        pkg)  value="$(get_pkg)"  ;;
        mem)  value="$(get_mem)"  ;;
        cpu)  value="$(get_cpu)"  ;;
        dsk)  value="$(get_dsk)"  ;;
        bat)  value="$(get_bat)"  ;;
        res)  value="$(get_res)"  ;;
        term) value="$(get_term)" ;;
        ip)   value="$(get_ip)"   ;;
        *)    echo "Unknown row: $key" >&2; return 1 ;;
    esac
    [[ -z "$value" ]] && return 1
    printf '%s%3s%s %s·%s %s' "$ACCENT" "$key" "$RESET" "$DIM" "$RESET" "$value"
}

build_dots() {
    local char spacing
    case "${DOTS:-small}" in
        small)  char='•'; spacing='  ' ;;
        medium) char='●'; spacing=' '  ;;
        square) char='▪'; spacing='  ' ;;
        none)   return ;;
        *)      char='•'; spacing='  ' ;;
    esac
    local out="" c esc=$'\033'
    for c in 31 32 33 34 35 36; do
        out+="${esc}[${c}m${char}${esc}[0m${spacing}"
    done
    printf '%s' "${out%"$spacing"}"
}

render() {
    local art_file="$ART_DIR/${ART:-nfo}.txt"
    [[ -f "$art_file" ]] || { echo "Error: Art not found: ${ART:-nfo} (looked in $ART_DIR)" >&2; return 1; }

    local -a art_lines=() info_lines=()
    local line override_cols=0 in_header=1
    while IFS= read -r line || [[ -n "$line" ]]; do
        if (( in_header )) && [[ "$line" =~ ^[[:space:]]*# ]]; then
            if [[ "$line" =~ ^[[:space:]]*#[[:space:]]*cols:[[:space:]]*([0-9]+) ]]; then
                override_cols="${BASH_REMATCH[1]}"
            fi
            continue
        fi
        in_header=0
        art_lines+=("$line")
    done < "$art_file"
    local last
    while (( ${#art_lines[@]} > 0 )); do
        last=$(( ${#art_lines[@]} - 1 ))
        [[ -z "${art_lines[$last]}" ]] || break
        unset "art_lines[$last]"
    done

    local art_w=0 al
    if (( override_cols > 0 )); then
        art_w=$override_cols
    else
        for al in "${art_lines[@]}"; do
            (( ${#al} > art_w )) && art_w=${#al}
        done
    fi

    if [[ "${SHOW_HOST:-True}" == "True" ]]; then
        local host_str rule
        host_str="$(get_host_line)"
        printf -v rule '%*s' "${#host_str}" ''
        rule="${rule// /─}"
        info_lines+=("${ACCENT}${host_str}${RESET}")
        info_lines+=("${DIM}${rule}${RESET}")
        info_lines+=("")
    fi

    if (( ${#INFO_ROWS[@]} > 0 )); then
        local row built
        for row in "${INFO_ROWS[@]}"; do
            if built="$(build_row "$row")"; then
                info_lines+=("$built")
            fi
        done
    fi

    local dots
    dots="$(build_dots)"
    if [[ -n "$dots" ]]; then
        info_lines+=("")
        info_lines+=("$dots")
    fi

    local art_h=${#art_lines[@]}
    local info_h=${#info_lines[@]}
    local total=$art_h
    (( info_h > total )) && total=$info_h

    local art_top_pad=0 info_top_pad=0
    if (( info_h > art_h )); then
        art_top_pad=$(( (info_h - art_h) / 2 ))
    elif (( art_h > info_h )); then
        info_top_pad=$(( (art_h - info_h) / 2 ))
    fi

    if (( DEV_MODE )); then
        printf '\n%s> nfo - dev mode enabled%s\n\n' "$DIM" "$RESET"
    else
        printf '\n%s> nfo%s\n\n' "$DIM" "$RESET"
    fi

    local margin info_col
    printf -v margin '%*s' "$LEFT_MARGIN" ""
    info_col=$(( LEFT_MARGIN + art_w + GAP ))

    local art_idx info_idx art info i
    for ((i=0; i<total; i++)); do
        art_idx=$(( i - art_top_pad ))
        if (( art_idx >= 0 && art_idx < art_h )); then
            art="${art_lines[art_idx]}"
        else
            art=""
        fi
        info_idx=$(( i - info_top_pad ))
        if (( info_idx >= 0 && info_idx < info_h )); then
            info="${info_lines[info_idx]}"
        else
            info=""
        fi
        if [[ -n "$info" ]]; then
            printf '%s%s\r\033[%dC%s\n' "$margin" "$art" "$info_col" "$info"
        else
            printf '%s%s\n' "$margin" "$art"
        fi
    done

    printf '\n'
}

main() {
    case "${1:-}" in
        -h|--help)    show_usage; exit 0 ;;
        -v|--version) show_version; exit 0 ;;
        ""|--super-secret-dev-mode) ;;
        *) echo "Error: Unknown option: $1" >&2
           echo "Run 'nfo --help' for usage." >&2
           exit 1 ;;
    esac

    init_config "$@"
    setup_styling
    render
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
